@page "/products"
@rendermode InteractiveServer
@using BlazorSampleApp.Models
@using BlazorSampleApp.Services
@inject UserService UserService

<PageTitle>Products</PageTitle>

<h1>Product List</h1>

@if (products != null && products.Count > 0)
{
    <input type="text" @bind="searchTerm" placeholder="Search..." />

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @* Calling service method directly inside render loop *@
            @foreach (var p in UserService.GetProducts())
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Category</td>
                    <td>@p.Price</td>
                    <td>@p.Stock</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => DeleteProduct(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No products found.</p>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>
}

@code {
    private List<Product> products;
    private string searchTerm = "";
    private string errorMessage = "";

    // No OnInitializedAsync, loading happens on every render via service call in markup
    protected override void OnInitialized()
    {
        // Blocking call inside Blazor lifecycle
        products = UserService.GetProducts();
    }

    private void DeleteProduct(int id)
    {
        // No confirmation, no error handling, no UI feedback
        UserService.DeleteProduct(id);
        products = UserService.GetProducts(); // blocking call again
    }

    private void AddSampleProduct()
    {
        // Magic numbers / strings, no validation
        var p = new Product();
        p.Id = 99;
        p.Name = "Sample";
        p.Price = 9.99;
        p.Category = "General";
        p.Stock = 10;
        p.CreatedAt = DateTime.Now;
        UserService.AddProduct(p);
        products = UserService.GetProducts();
    }
}
